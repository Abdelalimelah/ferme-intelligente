# =============================================
#  Ferme Intelligente — Environment Variables
#  Copy to .env and fill in your values
# =============================================

# ── Database ──────────────────────────────────
POSTGRES_DB=ferme_intelligente
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres           # CHANGE IN PRODUCTION

# ── Backend / JWT ─────────────────────────────
JWT_SECRET=ferme-intelligente-secret-change-this-in-production-min-32-chars
JWT_EXPIRATION=86400000              # 24 h in ms

# ── Frontend ──────────────────────────────────
VITE_API_URL=http://localhost:8080/api

# ── CORS ─────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── AI Service ───────────────────────────────
AI_SERVICE_URL=http://localhost:8001
MODEL_PATH=./model/weights/plant_disease_model.h5

# ── Upload ───────────────────────────────────
UPLOAD_DIR=./uploads/images
MAX_UPLOAD_SIZE=10MB

# ── Email (dev: Mailtrap free, prod: SendGrid/SES) ───────────
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_user
MAIL_PASSWORD=your_mailtrap_pass
MAIL_FROM=noreply@ferme-intelligente.ma
FRONTEND_URL=http://localhost

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
